# Local-only secrets/config (do not commit `.env`)
#
# This file is safe to commit. Copy to `.env` and fill values locally.

# Cloudflare token that can manage API tokens (create/revoke).
# Keep this token local and delete from `.env` after provisioning.
CLOUDFLARE_TOKEN_MGMT_TOKEN=

# Cloudflare account id that owns the Pages project.
CLOUDFLARE_ACCOUNT_ID=

# GitHub repo in OWNER/REPO form (optional; autodetected with `gh` if omitted).
GITHUB_REPO=

# Cloudflare Pages project name (used as a GitHub Actions variable).
CLOUDFLARE_PAGES_PROJECT=omt-assist-org

# Name to give the limited deploy token that the script provisions.
CLOUDFLARE_PAGES_DEPLOY_TOKEN_NAME=omt-assist-org-pages-deploy

# Optional override if the script cannot find the permission group automatically.
CLOUDFLARE_PAGES_PERMISSION_GROUP_ID=

# Optional expiry for the deploy token, RFC3339 / ISO8601 (example: 2026-12-31T23:59:59Z)
CLOUDFLARE_PAGES_DEPLOY_TOKEN_EXPIRES_ON=
